{
  "name": "@cloudfuze/ai-governance-agent",
  "version": "0.1.0",
  "description": "CloudFuze AI & Agent Governance — endpoint scanner",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ai-gov-agent": "./src/index.js",
    "ai-gov-server-monitor": "./src/server-monitor/index.js",
    "cfai-mcp-guard": "./src/mcp_guard/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "scan": "node src/index.js --output ./out/report.json --pretty",
    "scan:dry": "node src/index.js --dry-run --pretty",
    "server-monitor": "node src/server-monitor/index.js",
    "test": "node --test tests/",
    "build:bundle": "node scripts/build.mjs bundle",
    "build:sea": "node scripts/build.mjs sea",
    "build": "node scripts/build.mjs all"
  },
  "dependencies": {
    "@electron/asar": "^3.2.10",
    "better-sqlite3": "^11.5.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.8.0",
    "node-forge": "^1.4.0",
    "pdf-parse": "^1.1.1",
    "tesseract.js": "^5.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "postject": "^1.0.0-alpha.6"
  }
}
